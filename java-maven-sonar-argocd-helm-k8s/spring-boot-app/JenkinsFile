pipeline {

  agent {
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  stages {

    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/Badri-019/Jenkins-Zero-To-Hero.git'
      }
    }

    stage('Build and Test') {
      steps {
        sh '''
        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
        mvn clean package
        '''
      }
    }

    // SONAR RUNS ON HOST (Java 17)
    stage('Static Code Analysis') {

      agent any   // ✅ THIS IS THE KEY FIX

      environment {
        SONAR_URL = "http://20.197.58.116:9000"
      }

      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {

          sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app

          mvn clean verify sonar:sonar \
          -Dsonar.projectKey=spring-boot-app \
          -Dsonar.host.url=$SONAR_URL \
          -Dsonar.login=$SONAR_AUTH_TOKEN
          '''
        }
      }
    }

    stage('Build and Push Docker Image') {

      environment {
        DOCKER_IMAGE = "abhishekf5/ultimate-cicd:${BUILD_NUMBER}"
      }

      steps {
        script {

          sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
          docker build -t ${DOCKER_IMAGE} .
          '''

          def dockerImage = docker.image("${DOCKER_IMAGE}")

          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            dockerImage.push()
          }
        }
      }
    }

    stage('Update Deployment File') {

      environment {
        GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
        GIT_USER_NAME = "Badri-019"
      }

      steps {

        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {

          sh '''
          git config user.email "badrigunnampalli@gmail.com"
          git config user.name "badri gunnampalli"

          sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" \
          java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

          git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

          git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"

          git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
          '''
        }
      }
    }
  }
}
